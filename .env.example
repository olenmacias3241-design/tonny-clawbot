# Application Settings
APP_NAME=Claw Bot AI
APP_VERSION=0.1.0
DEBUG=false

# Server Configuration
HOST=0.0.0.0
PORT=8000

# AI Provider Settings
# Choose your default AI provider: "openai" or "anthropic"
DEFAULT_AI_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Anthropic Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-opus-20240229

# Database Configuration
DATABASE_URL=sqlite:///./claw_bot.db

# Redis Configuration (optional)
# REDIS_URL=redis://localhost:6379

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/claw_bot.log

# Bot Settings
MAX_CONTEXT_MESSAGES=10
RESPONSE_TIMEOUT=30

# 聊天操控电脑（传统龙虾能力）：通过聊天执行白名单内命令
# ENABLE_COMPUTER_CONTROL=false
# ALLOWED_COMMANDS=ls,pwd,date,whoami,open

# Email Settings
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com

# Telegram Settings
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_DEFAULT_CHAT_ID=your_default_chat_id

# WhatsApp Settings (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
WHATSAPP_FROM=whatsapp:+1234567890

# WhatsApp Business API (alternative to Twilio)
WHATSAPP_BUSINESS_TOKEN=your_whatsapp_business_token
WHATSAPP_PHONE_ID=your_whatsapp_phone_id

# GitHub（日报/周报同步 - 龙虾仓库）
# 多仓库逗号分隔，与下方单仓库二选一
GITHUB_REPOS=olenmacias3241-design/tonny-clawbot
# 单仓库时可改用：
# GITHUB_DEFAULT_OWNER=olenmacias3241-design
# GITHUB_DEFAULT_REPO=tonny-clawbot
# 私有仓库或提高限速需填 Personal Access Token
# GITHUB_TOKEN=your_github_personal_access_token

# SadTalker 口播（人物动嘴）：指定用于运行 SadTalker 的 Python（建议用项目内 SadTalker/venv）
# SADTALKER_PYTHON=/path/to/claw-bot-ai/SadTalker/venv/bin/python
